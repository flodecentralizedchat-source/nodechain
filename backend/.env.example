# ──────────────────────────────────────────────
# NodeChain Backend — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ──────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nodechain

# JWT Secret (generate a random 64-char string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ──────────────────────────────────────────────
# YOUR PROJECT WALLET (Ethereum)
# This wallet RECEIVES ETH from customers
# Generate with: node scripts/generateWallet.js
# ──────────────────────────────────────────────
PROJECT_WALLET_ADDRESS=0xYourProjectWalletAddressHere
PROJECT_WALLET_PRIVATE_KEY=your_private_key_here_keep_secret

# Ethereum RPC (get from Infura or Alchemy)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
# For testnet (Sepolia):
# ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# CoinGecko API (free tier works, optional key for higher rate limits)
COINGECKO_API_KEY=your_coingecko_api_key_optional
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Income Settings
INCOME_INTERVAL_HOURS=6
BASE_INCOME_RATE=0.0082

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
